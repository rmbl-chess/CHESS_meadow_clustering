venv/
env/
build/
dist/
site/         # mkdocs build output
_version.py   # hatch-vcs

# uv
.uv/
uv.lock        # uncomment to gitignore lockfile in apps; commit it for libraries

# R
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj
renv/library/
renv/local/
renv/lock/
renv/python/
renv/staging/
docs/         # pkgdown output (keep README.Rmd / vignettes; ignore built site)
inst/doc/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Geospatial — derived / large outputs (keep canonical inputs separately)
*.tif.aux.xml
*.tif.ovr
*.tif.msk
*.gpkg-shm
*.gpkg-wal
*.shp.iddx
*.gdb/
*.kmz~
*.zarr/        # comment out if zarr stores are tracked
*.tif.tmp

# Common output dirs (override per project — many of these are intentional)
output/
outputs/
results/
figs/
figures/
# docs/figures/ holds canonical archived figures (per repo convention).
!docs/figures/
!docs/figures/**
scratch/
tmp/
temp/

# Big data — explicitly ignore; check in canonical inputs separately if needed
data/raw/
data/derived/*
data/cache/

# Handoff artifacts that travel with the repo so cloud / collaborator
# runs of the Python tools don't require a full R pipeline rebuild.
!data/derived/target_pixels.csv
!data/derived/aop_classifier_pca.csv
!data/derived/aop_classifier_meta.json
!data/derived/aop_classifier_indices.csv
!data/derived/shrub_records.csv
!data/derived/shrub_taxonomy_crosswalk.csv
!data/derived/shrub_label_crosswalk.csv
!data/derived/shrub_training_set.csv
!data/derived/canopy_height.rds
!data/derived/joint_training_set.csv
!data/derived/punch_list.csv
!data/derived/punch_list_v1.csv
!data/derived/inference_predictions.csv
!data/derived/inference_pixel_distances.csv
!data/derived/novelty_by_class.csv
!data/derived/novelty_by_hex.gpkg
!data/derived/sampling_priority.gpkg
!data/derived/sampling_priority_top.csv
!data/derived/year_effect_points.csv
!data/derived/year_effect_points.gpkg
!data/derived/class_summary_table.csv
!data/derived/joint_training.gpkg
!data/derived/aop_classified/
!data/derived/aop_classified/class_lookup.csv
# Large per-domain rasters stay out of git (~340 MB total).
data/derived/aop_classified/*.tif
data/*.parquet
data/*.feather
*.h5
*.nc           # NetCDF — uncomment selectively if you commit small reference files

