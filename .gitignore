# Generic
.DS_Store
*.swp
*.bak
*~
.idea/
.vscode/
.claude/
*.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
